# =====================================
# Ink & Ember – Backend Environment
# =====================================

# ---------- Core ----------
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=ink_ember

ENV=development
LOG_LEVEL=INFO

# CORS (dev default; restrict only if you expose the API)
CORS_ORIGINS=*


# =====================================
# Import / Export Collaboration
# (Offline-first, no live editing)
# =====================================

# Master switch for import/export features
COLLAB_IMPORT_EXPORT_ENABLED=true

# Require signed export manifests on import
# Recommended when sharing vaults between people
REQUIRE_SIGNED_EXPORT=false

# Key used to sign/verify export manifests (HMAC)
# Only used if REQUIRE_SIGNED_EXPORT=true
EXPORT_SIGNING_KEY=change-me-before-enabling

# Allow encrypted exports (client- or server-side)
EXPORT_ENCRYPTION_ENABLED=false

# Key used for server-side encryption (optional)
EXPORT_ENCRYPTION_KEY=change-me-if-used

# Safety limits
EXPORT_MAX_MB=200
IMPORT_MAX_MB=200

# Import behavior
# true  = validate only unless explicitly committed
# false = imports apply immediately
IMPORT_DEFAULT_DRY_RUN=true
