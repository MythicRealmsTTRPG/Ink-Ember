# =====================================
# Ink & Ember – Frontend Environment
# =====================================

# ---------- Core ----------

# Backend API base URL
# Local by default (offline-first)
VITE_API_BASE_URL=http://localhost:8000/api

# Application environment
# development | production
VITE_ENV=development


# ---------- Theme Defaults ----------

# Preferred color mode
# dark | light
VITE_PREFERRED_COLOR_MODE=dark

# Default theme on first launch
VITE_DEFAULT_THEME=ink_and_ember


# ---------- Offline / Storage ----------

# Enable local vault storage (always true in practice)
VITE_LOCAL_STORAGE_ENABLED=true

# Namespace for local storage keys
VITE_STORAGE_NAMESPACE=ink-ember

# Autosave interval (ms)
VITE_AUTOSAVE_INTERVAL=2000


# ---------- Import / Export Collaboration ----------

# Enable Import / Export UI
VITE_IMPORT_EXPORT_ENABLED=true

# Default import behavior
# true  = dry-run first
# false = apply immediately
VITE_IMPORT_DEFAULT_DRY_RUN=true

# Max import/export size (MB)
VITE_IMPORT_MAX_MB=200
VITE_EXPORT_MAX_MB=200


# ---------- UX / Accessibility ----------

# Enable keyboard-first features (Cmd/Ctrl+K, etc.)
VITE_KEYBOARD_NAV_ENABLED=true

# Respect prefers-reduced-motion
VITE_REDUCED_MOTION_AWARE=true


# ---------- Debug ----------

# Show debug panels / logs in UI
VITE_DEBUG=false
